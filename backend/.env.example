# Server
NODE_ENV=development
PORT=3000

# MongoDB Atlas
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=

# JWT
# Use a long, random secret in production.
JWT_SECRET=
JWT_EXPIRES_IN=1h

# CORS (optional) - comma-separated list. Leave empty to allow all.
CORS_ORIGIN=http://localhost:4200
