{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/frontend/browser",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://YOUR_BACKEND_HOST.example.com/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}