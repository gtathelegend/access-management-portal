{
  "version": 2,
  "buildCommand": "sed -i \"s|BACKEND_API_URL_PLACEHOLDER|${BACKEND_API_URL:-/api/v1}|g\" src/environments/environment.production.ts && npm run build",
  "outputDirectory": "dist/frontend/browser",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}